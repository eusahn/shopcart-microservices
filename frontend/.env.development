# Local dev: vite proxies /api → http://localhost:18080 (api-gateway).
# Keycloak is brought up by docker-compose on :8181 with the shopcart realm
# pre-imported. Demo credentials: demo / demo

VITE_API_BASE=/api
VITE_KEYCLOAK_URL=http://localhost:8181
VITE_KEYCLOAK_REALM=shopcart
VITE_KEYCLOAK_CLIENT=shopcart-web

# Escape hatch: set to "true" to skip Keycloak entirely and pretend you're
# "dev-user". Requires the gateway to also run with AUTH_DISABLED=true.
VITE_AUTH_DISABLED=false
