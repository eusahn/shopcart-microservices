{
  "name": "shopcart",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "proto:gen": "buf generate",
    "proto:lint": "buf lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.45.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "turbo": "^2.2.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "overrides": {
      "@bufbuild/protobuf": "1.10.0"
    }
  }
}
