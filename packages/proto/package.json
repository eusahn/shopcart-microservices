    "./cart": "./dist/gen/cart/v1/cart_pb.js",
    "./cart-connect": "./dist/gen/cart/v1/cart_connect.js",
    "./user": "./dist/gen/user/v1/user_pb.js",
    "./user-connect": "./dist/gen/user/v1/user_connect.js",
    "./order": "./dist/gen/order/v1/order_pb.js",
    "./order-connect": "./dist/gen/order/v1/order_connect.js",
    "./inventory": "./dist/gen/inventory/v1/inventory_pb.js",
    "./inventory-connect": "./dist/gen/inventory/v1/inventory_connect.js",
    "./payment": "./dist/gen/payment/v1/payment_pb.js",
