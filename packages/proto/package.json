{
  "name": "@shopcart/proto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./catalog": "./dist/gen/catalog/v1/catalog_pb.js",
