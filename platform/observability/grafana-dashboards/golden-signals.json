{
  "title": "ShopCart — Golden Signals",
  "uid": "shopcart-golden",
  "schemaVersion": 39,
  "tags": ["shopcart"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_server_duration_milliseconds_count, service_name)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (service_name) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[1m]))", "legendFormat": "{{service_name}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Error rate (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 * sum by (service_name) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\",http_response_status_code=~\"5..\"}[1m])) / sum by (service_name) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[1m]))", "legendFormat": "{{service_name}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "p95 latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[1m])))", "legendFormat": "{{service_name}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Pod saturation: CPU / limit",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"shopcart\",container!=\"\",container!=\"POD\"}[1m])) / on(pod) group_left() sum by (pod) (kube_pod_container_resource_limits{namespace=\"shopcart\",resource=\"cpu\"})", "legendFormat": "{{pod}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
