{
  "name": "@shopcart/notification-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@shopcart/config": "workspace:*",
    "@shopcart/kafka": "workspace:*",
    "@shopcart/logger": "workspace:*",
    "@shopcart/otel": "workspace:*",
    "@shopcart/proto": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  }
}
